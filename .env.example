# Copy to .env and fill in.

# Signing secret from the SitRep Studio (shown once when you save a Remote agent).
# Leave blank for pure local dev — signature checks are skipped when unset.
SITREP_AGENT_SECRET=

# Public URL of THIS agent — used to build the dashboard link artifact.
# Local dev: leave as-is, or set to your tunnel URL. Deploy: your Render URL.
PUBLIC_URL=http://localhost:9000

# Where the ledger is stored. SQLite (default) needs no setup but is wiped on a
# free-host restart. For the submission, point this at a free hosted Postgres
# (Neon/Supabase) so the ledger survives — value compounds across meetings.
DATABASE_URL=sqlite+aiosqlite:///./ledger.db
# DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/DB

# ── LLM ───────────────────────────────────────────────────────────────
# Default: free local Ollama. Use a capable model — the 1b default is too weak
# for reliable structured extraction. Recommended:
#   ollama pull qwen2.5:7b      (best structured-output quality per GB)
#   ollama pull llama3.1:8b
LLM_BASE_URL=http://localhost:11434/v1
MODEL=qwen2.5:7b
# LLM_API_KEY is unused by Ollama.

# ── For the judged submission: flip to Claude (best extraction). ──────
# Anthropic exposes an OpenAI-compatible endpoint:
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_API_KEY=sk-ant-...
# MODEL=claude-haiku-4-5-20251001
#
# Other OpenAI-compatible providers work too (OpenAI, OpenRouter, vLLM, LM Studio).
